GEMINI_API_KEY=your_api_key_from_https://ai.google.dev/
GEMINI_IMAGE_MODELS=imagen-4.0-fast-generate-001,gemini-2.0-flash-preview-image-generation,gemini-2.5-flash-image

# Pipeline V2 defaults
COST_CAP_USD_DEFAULT=0.50
SCRIPT_PHASE_USD_ESTIMATE=0.01
IMAGE_PHASE_USD_ESTIMATE_EACH=0.02
VEO_PHASE_USD_ESTIMATE_PER_SECOND=0.10
RENDER_PHASE_USD_ESTIMATE=0.01
VEO_ENABLED_DEFAULT=true
VEO_CLIP_SECONDS=4
V2_ACT_GROUPS=1-3,4-5,6-8,9-10
ASSET_TTL_MINUTES=60

# Vertex AI / Veo
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VEO_MODEL=veo-3.0-fast-generate-preview
